{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "types": [ "node" ],

    // Other Outputs
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,

    "noEmit": false
  },
  "include": [ "src" ],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}