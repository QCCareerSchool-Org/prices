{
    "defaultSeverity": "error",
    "extends": [
        "tslint:recommended",
        "tslint-eslint-rules"
    ],
    "jsRules": {},
    "rules": {
      "max-line-length": false,
      "quotemark": [true, "single"],
      "object-literal-sort-keys": false,
      "array-bracket-spacing": [true, "always"],
      "ter-computed-property-spacing": [true, "never"],
      "interface-name": false
    },
    "rulesDirectory": []
}
